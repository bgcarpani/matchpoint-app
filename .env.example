# Supabase — copiar a .env.local y completar con los valores del proyecto.
# (Settings → API en el dashboard de Supabase)

# URL del proyecto y anon key: seguras para exponer al navegador (sujetas a RLS).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key: SECRETA, sólo server-side. NUNCA exponer al navegador.
# Usada por el admin client (inscripción pública, lookup_token, apertura automática).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email transaccional (Resend) — v3. Sólo server-side.
# API key del dashboard de Resend (https://resend.com → API Keys).
RESEND_API_KEY=re_your_api_key
# Remitente. Requiere dominio verificado en Resend; para dev podés usar
# "Matchpoint <onboarding@resend.dev>" (sólo envía a la casilla de tu cuenta).
EMAIL_FROM=Matchpoint <noreply@tudominio.com>

# URL pública del sitio. Fallback para construir URLs absolutas (emails, OG)
# donde no hay headers de request. Sin barra final.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
