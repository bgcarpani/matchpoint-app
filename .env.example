# Supabase — copiar a .env.local y completar con los valores reales del proyecto.
# NOTA: Supabase migró a keys "sb_publishable_" (antes anon) y "sb_secret_" (antes service_role).
# Se mantienen los nombres de variable del código; el valor es la key nueva equivalente.
# NO pegar secretos reales en este archivo: está trackeado en git (ver .gitignore: !.env.example).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# Publishable key (segura para el navegador, sujeta a RLS) = "anon" en el código
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_key

# Secret key (SOLO server-side, bypassea RLS). Usada por el admin client
# (inscripción pública, lookup_token, carga manual de parejas).
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_key

# --- Solo para aplicar migraciones desde acá (Management API) ---
# Personal Access Token: https://supabase.com/dashboard/account/tokens (empieza con sbp_)
# Se puede revocar después de aplicar las migraciones.
SUPABASE_ACCESS_TOKEN=sbp_your_personal_access_token
SUPABASE_PROJECT_REF=your-project-ref

# Email transaccional (Resend) — v3. Solo server-side.
RESEND_API_KEY=re_your_api_key
# Remitente. Requiere dominio verificado; para dev: "Matchup <onboarding@resend.dev>"
# (solo entrega a la casilla exacta de tu cuenta de Resend).
EMAIL_FROM=Matchup <onboarding@resend.dev>

# URL pública del sitio. Fallback para URLs absolutas (emails, OG) sin headers de request.
# Sin barra final. En Cloudflare (producción) = la URL del deploy.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
