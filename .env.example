# Supabase — copiar a .env.local y completar con los valores del proyecto.
# (Settings → API en el dashboard de Supabase)

# URL del proyecto y anon key: seguras para exponer al navegador (sujetas a RLS).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key: SECRETA, sólo server-side. NUNCA exponer al navegador.
# Usada por el admin client (inscripción pública, lookup_token, apertura automática).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
